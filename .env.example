# ----------------------------------------------------------------------------
# Matic E-Commerce Backend - Environment Variables
# Copy this file to ".env" and fill in real values.
# ----------------------------------------------------------------------------

# App
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# CORS (comma separated list of allowed origins, or * for all)
CORS_ORIGIN=*

# PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# When running with docker-compose, HOST is the service name "db".
DATABASE_URL=postgresql://matic:matic_password@localhost:5432/matic_db?schema=public

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_super_long_random_string
JWT_REFRESH_SECRET=change_me_refresh_secret_super_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Default admin account created by the seed script
ADMIN_EMAIL=admin@matic.rw
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Matic Administrator

# Payments (innovation feature) - leave blank to use the built-in mock gateway
STRIPE_SECRET_KEY=
MOMO_API_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
